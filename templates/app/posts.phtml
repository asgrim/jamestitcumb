<?php

declare(strict_types=1);

use Asgrim\Value\Post;

/**
 * @var Post[] $posts
 * @var string $title
 */

$this->headTitle()->append($title);
$blogPostMarketing = $this->partial('partial::blog-post-marketing');
$outdatedCutoff = new DateTimeImmutable('-6 months');

$this->headScript()->appendScript('window.Prism = window.Prism || {}; Prism.manual = true;');
$this->headScript()->appendFile('https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-core.min.js');
$this->headScript()->appendFile('https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js');
$this->headScript()->appendScript(<<<'JS'
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('pre > code[class]').forEach(function (el) {
        if (!/\blanguage-/.test(el.className)) {
            el.classList.add('language-' + el.className.trim());
        }
    });
    Prism.highlightAll();
});
JS);
?>

<?php foreach ($posts as $post): ?>
<article style="margin-bottom: 60px;">
	<div class="article-header">
		<h1><a href="<?= $this->url('posts', ['slug' => $post->slug()]); ?>"><?= $this->escapeHtml($post->title()); ?></a></h1>
		<p class="article-meta">
			Posted on <?= $post->date()->format('jS F Y'); ?>
		</p>
	</div>
	<hr />
	<?php if ($post->shouldShowComments() && $post->date() < $outdatedCutoff): ?>
		<div class="notice notice--outdated">
			<p>This post is from <?= $post->date()->format('jS F Y'); ?> and may be outdated. It's kept here for reference.</p>
		</div>
	<?php endif; ?>
	<div class="article-body">
		<?= str_replace('<!-- MARKETING -->', $blogPostMarketing, $this->renderPostContent($post->slug())) ?>
	</div>

	<?php if ($post->shouldShowComments()): ?>
		<hr />
	<?php endif; ?>

</article>
<?php endforeach; ?>
